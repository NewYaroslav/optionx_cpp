# Intrade Bar API smoke test configuration.
# Copy values into an untracked *.local.env file or export them as environment variables.
# Do not commit real credentials or proxy values.

OPTIONX_INTRADE_BAR_EMAIL=
OPTIONX_INTRADE_BAR_PASSWORD=

# Either set the combined value as host:port:user:password...
OPTIONX_INTRADE_BAR_PROXY=

# ...or set server/auth separately.
OPTIONX_INTRADE_BAR_PROXY_SERVER=
OPTIONX_INTRADE_BAR_PROXY_AUTH=
OPTIONX_INTRADE_BAR_PROXY_TYPE=HTTP

OPTIONX_INTRADE_BAR_ACCOUNT_TYPE=DEMO
OPTIONX_INTRADE_BAR_CURRENCY=USD
OPTIONX_INTRADE_BAR_AUTO_FIND_DOMAIN=0
# Negative min excludes https://intrade.bar; e.g. -1 scans intrade1.bar...
OPTIONX_INTRADE_BAR_DOMAIN_MIN=0
OPTIONX_INTRADE_BAR_DOMAIN_MAX=1000
OPTIONX_INTRADE_BAR_HOST=https://intrade.bar
OPTIONX_INTRADE_BAR_AUTH_TIMEOUT_MS=90000
OPTIONX_INTRADE_BAR_PRICE_TIMEOUT_MS=30000
OPTIONX_INTRADE_BAR_TRADE_OPEN_TIMEOUT_MS=45000
OPTIONX_INTRADE_BAR_BALANCE_CHECK_PERIOD_MS=15000
OPTIONX_INTRADE_BAR_SETTINGS_SWITCH_TIMEOUT_MS=120000
OPTIONX_INTRADE_BAR_SETTINGS_SWITCH_RETRY_TIMEOUT_MS=600000
OPTIONX_INTRADE_BAR_SETTINGS_SWITCH_RETRY_DELAY_MS=15000
OPTIONX_INTRADE_BAR_SETTINGS_SWITCH_ACTIVE_TRADE_BUFFER_MS=5000

OPTIONX_INTRADE_BAR_QUOTE_SYMBOL=EURUSD
OPTIONX_INTRADE_BAR_TRADE_SYMBOL=EURUSD
OPTIONX_INTRADE_BAR_TRADE_ORDER_TYPE=BUY
OPTIONX_INTRADE_BAR_TRADE_AMOUNT=1.0
OPTIONX_INTRADE_BAR_TRADE_DURATION_SEC=60
OPTIONX_INTRADE_BAR_ALLOW_TRADE=0
OPTIONX_INTRADE_BAR_ALLOW_REAL_TRADE=0
OPTIONX_INTRADE_BAR_CLI_CONSOLE_LOG=0
