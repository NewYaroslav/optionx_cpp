//@version=6
indicator("optionx_cpp Noisy Test Signals", overlay=true)

rsi_len = input.int(7, "RSI Length")
level = input.float(50.0, "RSI Center Level")

r = ta.rsi(close, rsi_len)

buySignal = ta.crossover(r, level)
sellSignal = ta.crossunder(r, level)

plotshape(buySignal, title="BUY", text="BUY", style=shape.triangleup, location=location.belowbar, size=size.tiny)
plotshape(sellSignal, title="SELL", text="SELL", style=shape.triangledown, location=location.abovebar, size=size.tiny)

if buySignal
    alert('{"source":"tradingview","signal_name":"noisy_rsi_test","action":"buy","symbol":"' + syminfo.ticker + '","tickerid":"' + syminfo.tickerid + '","price":' + str.tostring(close) + ',"time":' + str.tostring(time) + '}', alert.freq_once_per_bar)

if sellSignal
    alert('{"source":"tradingview","signal_name":"noisy_rsi_test","action":"sell","symbol":"' + syminfo.ticker + '","tickerid":"' + syminfo.tickerid + '","price":' + str.tostring(close) + ',"time":' + str.tostring(time) + '}', alert.freq_once_per_bar)
